# Ingestion config consumed by src/ingestion/data_ingestion.py
# (loaded via yaml.safe_load; keys here map 1:1 to what the code reads).

eia:
  base_url: "https://api.eia.gov/v2/electricity/rto/region-data/data/"
  frequency: "hourly"
  regions:            # `respondent` facet — balancing authorities
    - PJM
    - CISO
    - ERCO
  series_types:       # `type` facet
    - D                # actual demand (target)
    - DF               # EIA day-ahead forecast (baseline)
  page_size: 5000     # EIA hard cap on `length`

retry:
  max_attempts: 5
  backoff_factor: 1.5           # 0s, 1.5s, 3s, 6s, 12s ...
  status_forcelist: [429, 500, 502, 503, 504]

ingestion:
  request_timeout: 30           # seconds
  default_lookback_days: 1095   # ~3 years when start/end not passed

s3:
  prefix: "gridcast/raw/eia"
