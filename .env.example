# Copy to .env (gitignored) and fill in. Loaded by python-dotenv in dev.
# ---------------------------------------------------------------------------

# --- EIA (https://www.eia.gov/opendata/register.php — free, instant key) ---
EIA_API_KEY=your_eia_api_key_here


# --- AWS / S3 (raw landing) ---
GRIDCAST_S3_BUCKET=your_s3_bucket_name
AWS_REGION=your_aws_region
# Prefer `aws configure` over hardcoding these:
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# --- Snowflake (30-day trial) ---
SNOWFLAKE_ACCOUNT=your_snowflake_account        # e.g. ab12345.us-east-1
SNOWFLAKE_USER=your_snowflake_user
SNOWFLAKE_PASSWORD=your_snowflake_password
SNOWFLAKE_ROLE=your_snowflake_role
SNOWFLAKE_WAREHOUSE=your_snowflake_warehouse
SNOWFLAKE_DATABASE=your_snowflake_database
SNOWFLAKE_SCHEMA=RAW

# --- MLflow ---
MLFLOW_TRACKING_URI=http://localhost:5000

# --- API location the dashboard calls ---
GRIDCAST_API_URL=http://localhost:8000
